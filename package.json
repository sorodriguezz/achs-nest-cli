{
  "name": "achs-nest-cli",
  "version": "1.1.1",
  "description": "Per-project scaffolding CLI for NestJS (files & schematics generator)",
  "license": "MIT",
  "readme": "README.md",
  "private": false,
  "author": "sorodriguezz",
  "bin": {
    "achs-nest": "dist/index.js",
    "anc": "dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "README.es.md"
  ],
  "keywords": [
    "nestjs",
    "cli",
    "scaffolding",
    "generator",
    "schematics",
    "typescript",
    "devtools"
  ],
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "ncc build src/bin.ts -o dist --minify",
    "dev": "ncc build src/bin.ts -o dist --watch",
    "prepare": "ncc build src/bin.ts -o dist --minify",
    "prepublishOnly": "ncc build src/bin.ts -o dist --minify"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "@vercel/ncc": "0.44.0",
    "chalk": "5.6.2",
    "commander": "15.0.0",
    "handlebars": "4.7.9",
    "ts-morph": "28.0.0",
    "typescript": "6.0.3"
  }
}
