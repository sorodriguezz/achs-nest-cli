{
  "name": "achs-nest-cli",
  "version": "1.0.1",
  "description": "Per-project scaffolding CLI for NestJS (files & schematics generator)",
  "license": "MIT",
  "readme": "README.md",
  "private": false,
  "author": "sorodriguezz",
  "bin": {
    "achs-nest": "dist/bin.js",
    "anc": "dist/bin.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "keywords": [
    "nestjs",
    "cli",
    "scaffolding",
    "generator",
    "schematics",
    "typescript",
    "devtools"
  ],
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "5.6.2",
    "commander": "14.0.2",
    "handlebars": "4.7.8",
    "ts-morph": "27.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "0.27.2",
    "typescript": "5.9.3"
  }
}
